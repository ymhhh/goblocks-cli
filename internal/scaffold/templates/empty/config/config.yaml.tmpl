server:
  http:
    addr: ":8080"
    tls:
      enabled: false
      cert_file: ""
      key_file: ""
    h3:
      enabled: false
      addr: ":8443"
    health:
      enabled: true
      liveness_path: /health
      readiness_path: /ready
  grpc:
    enabled: false
    addr: ":9090"
resilience:
  breaker:
    max_requests: 3
    consecutive_failures: 3
    interval: 60s
    timeout: 30s
  rate_limit:
    backend: memory
    # redis:
    #   addr: "redis://localhost:6379/0"
    #   key_prefix: "goblocks:rl:"
    global:
      rps: 100
      burst: 200
    user:
      enabled: false
      default_rps: 20
      burst: 40
ai:
  enabled: false
  base_url: "https://api.openai.com/v1"
  api_key: "${OPENAI_API_KEY}"
  model: "gpt-4o-mini"
logger:
  level: info
  format: text
  output: stderr
metrics:
  enabled: true
  path: "/metrics"
