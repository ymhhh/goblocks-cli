package infrastructure

import (
	"context"
	"errors"
	"log/slog"
	"net/http"

	"github.com/gin-gonic/gin"
	gblocksapp "github.com/ymhhh/goblocks/app"
	"github.com/ymhhh/goblocks/config"
	"github.com/ymhhh/goblocks/resilience"
	"{{.ModulePath}}/domain"
	"{{.ModulePath}}/handlers"
)

// Run loads config and starts the application.
func Run(configPath string) error {
	cfg, err := config.Load(configPath)
	if err != nil {
		return err
	}

	app, err := NewApp(Config{ConfigPath: configPath})
	if err != nil {
		return err
	}

	gblocks := gblocksapp.New(cfg)
{{- if .WithAI}}
	if cfg.AI.Enabled {
		app.AIHandler = handlers.NewAIHandler(gblocks)
	}
{{- end}}

	gblocks = gblocks.WithHTTP(app.registerHTTP)
	if cfg.Server.GRPC.Enabled {
		gblocks = gblocks.WithGRPC(app.registerGRPC)
	}

	if cfg.Server.GRPC.Enabled {
		slog.Info("starting service", "http", cfg.Server.HTTP.Addr, "grpc", cfg.Server.GRPC.Addr)
	} else {
		slog.Info("starting service", "http", cfg.Server.HTTP.Addr)
	}
	return gblocks.Run(context.Background())
}

func (a *App) registerHTTP(engine *gin.Engine, _ *resilience.Policy) {
	engine.GET("/health", func(c *gin.Context) {
		c.JSON(http.StatusOK, gin.H{"status": "ok"})
	})

	engine.GET("/users/:id", func(c *gin.Context) {
		id := c.Param("id")
		ctx := handlers.WithUserID(c.Request.Context(), id)
		user, err := a.UserHandler.GetUserInfo(ctx)
		if err != nil {
			c.JSON(userErrorStatus(err), gin.H{"error": err.Error()})
			return
		}
		c.JSON(http.StatusOK, user)
	})

{{- if .WithAI}}
	if a.AIHandler != nil {
		engine.POST("/ai/chat", a.AIHandler.Chat)
	}
{{- end}}
}

func userErrorStatus(err error) int {
	if errors.Is(err, domain.ErrNotFound) {
		return http.StatusNotFound
	}
	if errors.Is(err, domain.ErrInvalidID) {
		return http.StatusBadRequest
	}
	return http.StatusInternalServerError
}
