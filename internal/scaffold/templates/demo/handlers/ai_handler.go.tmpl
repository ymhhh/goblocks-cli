package handlers

import (
	"net/http"

	"github.com/gin-gonic/gin"
	gblocksapp "github.com/ymhhh/goblocks/app"
	"github.com/ymhhh/goblocks/ai"
)

// AIHandler handles AI chat use cases.
type AIHandler struct {
	client ai.Client
}

// NewAIHandler creates an AIHandler.
func NewAIHandler(app *gblocksapp.App) *AIHandler {
	return &AIHandler{client: app.AIClient()}
}

type chatRequest struct {
	Message string `json:"message" binding:"required"`
}

type chatResponse struct {
	Reply string `json:"reply"`
	Model string `json:"model"`
}

// Chat handles POST /ai/chat.
func (h *AIHandler) Chat(c *gin.Context) {
	var req chatRequest
	if err := c.ShouldBindJSON(&req); err != nil {
		c.JSON(http.StatusBadRequest, gin.H{"error": err.Error()})
		return
	}

	resp, err := h.client.Chat(c.Request.Context(), ai.ChatRequest{
		Messages: []ai.Message{
			{Role: "user", Content: req.Message},
		},
	})
	if err != nil {
		c.JSON(http.StatusBadGateway, gin.H{"error": err.Error()})
		return
	}

	c.JSON(http.StatusOK, chatResponse{
		Reply: resp.Content,
		Model: resp.Model,
	})
}
